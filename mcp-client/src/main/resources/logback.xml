<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%logger{25}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 业务日志：INFO -->
    <logger name="com.example.mcp" level="INFO"/>

    <!-- MCP 协议层：只看收发消息（INFO），屏蔽握手细节（DEBUG） -->
    <logger name="MCP" level="INFO"/>
    <logger name="dev.langchain4j.mcp" level="WARN"/>

    <!-- OkHttp / okio：屏蔽连接级别噪音 -->
    <logger name="okhttp3" level="WARN"/>
    <logger name="okio" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
